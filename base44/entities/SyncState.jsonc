{
  "name": "SyncState",
  "type": "object",
  "properties": {
    "page_token": {
      "type": "string",
      "description": "Google Drive sync page token"
    },
    "last_sync": {
      "type": "string",
      "format": "date-time",
      "description": "Last sync timestamp"
    }
  },
  "required": [
    "page_token"
  ]
}