{
  "name": "ChatLog",
  "type": "object",
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Browser session ID"
    },
    "user_email": {
      "type": "string",
      "description": "User email if authenticated"
    },
    "page_name": {
      "type": "string",
      "description": "Page where chat occurred"
    },
    "user_message": {
      "type": "string",
      "description": "What the user asked"
    },
    "ai_response": {
      "type": "string",
      "description": "What the AI responded"
    },
    "user_agent": {
      "type": "string",
      "description": "Browser/device info"
    }
  },
  "required": [
    "session_id",
    "user_message"
  ]
}